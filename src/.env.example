# Base URL of the application
# Em produção, use o domínio real (ex: https://paroquia.vercel.app)
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email (Resend)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Paróquia Manager <contato@seu-dominio.com.br>"

# NextAuth Secret (Gere um com `openssl rand -base64 32`)
AUTH_SECRET=

# Database Connection (URL do seu banco Postgres em produção)
DATABASE_URL=
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model users {
  id                String              @id @default(uuid())
  full_name         String?             @db.VarChar(255)
  email             String              @unique @db.VarChar(254)
  email_verified    DateTime?           @db.Timestamptz(6)
  password          String              @db.VarChar(255)
  role              String              @default("FIEL") @db.VarChar(255)
  created_at        DateTime            @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?           @db.Timestamptz(6)
  catechism_classes catechism_classes[]
  events            events[]
  pastoral_members  pastoral_members[]
  verification_tokens verification_tokens[]
}

enum TokenType {
  PASSWORD_RESET
  EMAIL_VERIFICATION
}

model verification_tokens {
  id         String    @id @default(uuid())
  user_id    String
  token      String    @unique
  type       TokenType
  expires_at DateTime  @db.Timestamptz(6)
  used_at    DateTime? @db.Timestamptz(6)
  created_at DateTime  @default(now()) @db.Timestamptz(6)

  user       users     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([user_id])
  @@index([expires_at])
}

model pastorals {
  id          String   @id @default(uuid())
  slug        String   @unique @db.VarChar(50)
  name        String   @db.VarChar(255)
  description String?
  image_url   String?
  instagram        String?
  meeting_location String?
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @db.Timestamptz(6)
  events      events[]
  members     pastoral_members[]
}

model pastoral_members {
  id          String   @id @default(uuid())
  user_id     String
  pastoral_id String
  role        String   @default("MEMBER") @db.VarChar(50) // e.g., "COORDENADOR", "MEMBER"
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  user     users     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  pastoral pastorals @relation(fields: [pastoral_id], references: [id], onDelete: Cascade)

  @@unique([user_id, pastoral_id])
}

model events {
  id            String     @id @default(uuid())
  title         String     @db.VarChar(255)
  description   String?
  image_url     String?
  start_date    DateTime?  @db.Timestamptz(6)
  end_date      DateTime?  @db.Timestamptz(6)
  type          String     @default("EVENT") @db.VarChar(50)
  meeting_location String?   @db.VarChar(255)
  is_active     Boolean    @default(true)
  pastoral_id   String?
  created_by_id String
  created_at    DateTime   @default(now()) @db.Timestamptz(6)
  updated_at    DateTime   @default(now()) @db.Timestamptz(6)
  author        users      @relation(fields: [created_by_id], references: [id])
  pastoral      pastorals? @relation(fields: [pastoral_id], references: [id])

  @@index([pastoral_id])
  @@index([start_date, end_date])
}

model catechism_classes {
  id          String               @id @default(uuid())
  name        String               @db.VarChar(255)
  year        Int
  catechist_id String?
  created_at  DateTime?            @db.Timestamptz(6)
  updated_at  DateTime?            @db.Timestamptz(6)
  attendances attendances[]
  catechist   users?               @relation(fields: [catechist_id], references: [id])
  meetings    catechism_meetings[]
  students    catechism_students[]
}

model catechism_students {
  id                  String             @id @default(uuid())
  name                String             @db.VarChar(255)
  class_id            String?
  status              String             @default("ACTIVE")
  created_at          DateTime?          @db.Timestamptz(6)
  updated_at          DateTime?          @db.Timestamptz(6)
  has_baptism         Boolean            @default(false)
  has_first_eucharist Boolean            @default(false)
  attendances         attendances[]
  class               catechism_classes? @relation(fields: [class_id], references: [id], onDelete: Cascade)
}

model catechism_meetings {
  id          String            @id @default(uuid())
  class_id    String
  date        DateTime
  attendances attendances[]
  class       catechism_classes @relation(fields: [class_id], references: [id])

  @@unique([class_id, date])
}

model attendances {
  id                   String              @id @default(uuid())
  class_id             String?
  catechism_meeting_id String?
  date                 DateTime            @db.Date
  present              Boolean?            @default(false)
  created_at           DateTime?           @db.Timestamptz(6)
  updated_at           DateTime?           @db.Timestamptz(6)
  catechism_student_id String?
  meeting              catechism_meetings? @relation(fields: [catechism_meeting_id], references: [id], onDelete: Cascade)
  student              catechism_students? @relation(fields: [catechism_student_id], references: [id], onDelete: Cascade)
  class                catechism_classes?  @relation(fields: [class_id], references: [id], onDelete: Cascade)

  @@unique([class_id, catechism_student_id, date])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model attendances {
  id                   Int                 @id @default(autoincrement())
  class_id             Int?
  catechism_meeting_id Int?
  date                 DateTime            @db.Date
  present              Boolean?            @default(false)
  created_at           DateTime?           @db.Timestamptz(6)
  updated_at           DateTime?           @db.Timestamptz(6)
  catechism_student_id Int?
  catechism_students   catechism_students? @relation(fields: [catechism_student_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "attendances_catechism_student_id_foreign")
  catechism_classes    catechism_classes?  @relation(fields: [class_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "attendances_class_id_foreign")
  catechism_meetings   catechism_meetings? @relation(fields: [catechism_meeting_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "attendances_catechism_meeting_id_foreign")

  @@unique([class_id, catechism_student_id, date])
}

model catechism_classes {
  id                 Int                  @id @default(autoincrement())
  name               String               @db.VarChar(255)
  year               Int
  catechist_id       Int?
  created_at         DateTime?            @db.Timestamptz(6)
  updated_at         DateTime?            @db.Timestamptz(6)
  attendances        attendances[]
  users              users?               @relation(fields: [catechist_id], references: [id], onUpdate: NoAction, map: "catechism_classes_catechist_id_foreign")
  catechism_students catechism_students[]
  meetings           catechism_meetings[]
}

model catechism_students {
  id                  Int                @id @default(autoincrement())
  name                String             @db.VarChar(255)
  class_id            Int?
  status              String             @default("ACTIVE")
  created_at          DateTime?          @db.Timestamptz(6)
  updated_at          DateTime?          @db.Timestamptz(6)
  has_baptism         Boolean            @default(false)
  has_first_eucharist Boolean            @default(false)
  attendances         attendances[]
  catechism_classes   catechism_classes? @relation(fields: [class_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "catechism_students_class_id_foreign")
}

model catechism_meetings {
  id       Int      @id @default(autoincrement())
  class_id Int
  date     DateTime

  catechism_classes catechism_classes @relation(fields: [class_id], references: [id])
  attendances       attendances[]

  @@unique([class_id, date])
}

model users {
  id                Int                 @id @default(autoincrement())
  full_name         String?             @db.VarChar(255)
  email             String              @unique(map: "users_email_unique") @db.VarChar(254)
  password          String              @db.VarChar(255)
  role              String              @default("FIEL") @db.VarChar(255)
  created_at        DateTime            @db.Timestamptz(6)
  updated_at        DateTime?           @db.Timestamptz(6)
  catechism_classes catechism_classes[]
}
